# ============================================================
# SENAI — Biblioteca · Reservas
# Copie este arquivo para `.env` e ajuste os valores conforme o ambiente.
# Variáveis com prefixo VITE_ são expostas ao client (browser).
# Variáveis sem prefixo VITE_ ficam apenas no servidor (server functions).
# ============================================================

# ---- URLs públicas da aplicação ----
VITE_APP_NAME="SENAI Biblioteca"
VITE_APP_URL="http://localhost:3000"

# ---- Backend / API (a ser implementado) ----
# Base URL da API REST do backend
VITE_API_URL="http://localhost:8080/api"
# Versão da API (opcional)
VITE_API_VERSION="v1"
# Timeout padrão para requisições HTTP (ms)
VITE_API_TIMEOUT="15000"

# ---- Autenticação ----
# URL do servidor de auth (ex.: Keycloak, Auth0, backend próprio)
VITE_AUTH_URL="http://localhost:8080/auth"
# Chave usada para assinar/validar JWT no servidor
AUTH_JWT_SECRET="troque-este-valor-em-producao"
AUTH_JWT_EXPIRES_IN="8h"

# ---- Banco de dados (servidor) ----
DATABASE_URL="postgresql://usuario:senha@localhost:5432/senai_biblioteca"

# ---- WebSocket / Realtime (opcional) ----
VITE_WS_URL="ws://localhost:8080/ws"

# ---- E-mail (notificações de reserva/confirmação) ----
SMTP_HOST="smtp.senai.br"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="biblioteca@senai.br"

# ---- Regras de negócio (sobrescrevem defaults do front, opcional) ----
VITE_OPENING_HOUR="7"
VITE_CLOSING_HOUR="22"
VITE_CANCEL_LIMIT_MINUTES="30"
VITE_CONFIRM_LIMIT_MINUTES="60"
VITE_CHECKIN_WINDOW_MINUTES="15"
VITE_NO_SHOW_AFTER_MINUTES="20"
